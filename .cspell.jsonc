{
  "language": "en",
  "ignorePaths": [
    "**/*.d.ts",
    "**/*.log",
    ".claude/worktrees/**/*",
    ".complexipy_cache/**/*",
    ".pytest_cache/**/*",
    ".rumdl_cache/**/*",
    ".vale/**/*",
    ".venv/**/*",
    "coverage.json",
    "coverage.xml",
    "dist/**/*",
    "LICENSE",
    "node_modules/**/*",
    "tmp/**/*",
    "uv.lock"
  ],
  "dictionaryDefinitions": [
    {
      "name": "proofhouse",
      "path": "./.cspell-words.txt",
      "addWords": true
    }
  ],
  "dictionaries": ["proofhouse", "python"]
}
